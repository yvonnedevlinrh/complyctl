  <definitions>
    <definition class="compliance" id="oval:com.redhat.rhsa:def:fedora_supported_version" version="1">
      <metadata>
        <title>Fedora Supported Version Check</title>
        <affected family="unix">
          <platform>Fedora</platform>
        </affected>
        <description>Verify that the system is running Fedora 43 or newer</description>
      </metadata>
      <criteria>
        <criterion comment="Fedora version is 43 or greater" test_ref="oval:com.redhat.rhsa:tst:fedora_version_43"/>
      </criteria>
    </definition>
  </definitions>

  <tests>
    <ind-def:textfilecontent54_test check="all" check_existence="all_exist"
                                     comment="Check Fedora version from os-release"
                                     id="oval:com.redhat.rhsa:tst:fedora_version_43" version="1">
      <ind-def:object object_ref="oval:com.redhat.rhsa:obj:os_release_version"/>
      <ind-def:state state_ref="oval:com.redhat.rhsa:ste:fedora_version_43_or_greater"/>
    </ind-def:textfilecontent54_test>
  </tests>

  <objects>
    <ind-def:textfilecontent54_object id="oval:com.redhat.rhsa:obj:os_release_version" version="1">
      <ind-def:filepath>/etc/os-release</ind-def:filepath>
      <ind-def:pattern operation="pattern match">^VERSION_ID=(\d+)$</ind-def:pattern>
      <ind-def:instance datatype="int">1</ind-def:instance>
    </ind-def:textfilecontent54_object>
  </objects>

  <states>
    <ind-def:textfilecontent54_state id="oval:com.redhat.rhsa:ste:fedora_version_43_or_greater" version="1">
      <ind-def:subexpression datatype="int" operation="greater than or equal">43</ind-def:subexpression>
    </ind-def:textfilecontent54_state>
  </states>
